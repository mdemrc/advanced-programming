@model IEnumerable<Bookstore.Models.Book>

@{
    ViewData["Title"] = "Books Directory";
}

<h1>Books Directory</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Book</a>
</p>

<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="SearchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search by title, ISBN, or author name..." />
        <button type="submit" class="btn btn-outline-secondary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["TitleSortParm"]" asp-route-currentFilter="@ViewData["CurrentFilter"]">Title</a>
            </th>
            <th>
                Author
            </th>
            <th>
                Category
            </th>
            <th>
                ISBN
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["PriceSortParm"]" asp-route-currentFilter="@ViewData["CurrentFilter"]">Price</a>
            </th>
            <th>
                Stock
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["DateSortParm"]" asp-route-currentFilter="@ViewData["CurrentFilter"]">Published Date</a>
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <strong>@Html.DisplayFor(modelItem => item.Title)</strong>
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Author.FullName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Category.Name)
                </td>
                <td>
                    <code>@Html.DisplayFor(modelItem => item.ISBN)</code>
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Price)
                </td>
                <td>
                    @if (item.Stock == 0)
                    {
                        <span class="badge bg-danger">Out of stock</span>
                    }
                    else if (item.Stock < 5)
                    {
                        <span class="badge bg-warning text-dark">Low Stock (@item.Stock)</span>
                    }
                    else
                    {
                        <span class="badge bg-success">@item.Stock</span>
                    }
                </td>
                <td>
                    @item.PublishedDate.ToString("yyyy-MM-dd")
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@{
    var prevDisabled = !(bool)ViewData["HasPreviousPage"] ? "disabled" : "";
    var nextDisabled = !(bool)ViewData["HasNextPage"] ? "disabled" : "";
}

<nav aria-label="Book list navigation">
    <ul class="pagination justify-content-center">
        <li class="page-item @prevDisabled">
            <a asp-action="Index"
               asp-route-sortOrder="@ViewData["CurrentSort"]"
               asp-route-pageNumber="@((int)ViewData["PageIndex"] - 1)"
               asp-route-currentFilter="@ViewData["CurrentFilter"]"
               class="page-link">Previous</a>
        </li>
        <li class="page-item disabled">
            <span class="page-link">Page @ViewData["PageIndex"] of @ViewData["TotalPages"]</span>
        </li>
        <li class="page-item @nextDisabled">
            <a asp-action="Index"
               asp-route-sortOrder="@ViewData["CurrentSort"]"
               asp-route-pageNumber="@((int)ViewData["PageIndex"] + 1)"
               asp-route-currentFilter="@ViewData["CurrentFilter"]"
               class="page-link">Next</a>
        </li>
    </ul>
</nav>
