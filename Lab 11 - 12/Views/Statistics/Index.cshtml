@model Bookstore.Models.BookstoreStatsViewModel

@{
    ViewData["Title"] = "Business Dashboard";
}

<h1>Business Dashboard</h1>
<p class="text-muted">A live statistics panel compiled via advanced LINQ aggregates.</p>
<hr />

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card text-white bg-primary mb-3">
            <div class="card-header">Total Revenue</div>
            <div class="card-body">
                <h2 class="card-title">@Model.TotalRevenue.ToString("C")</h2>
                <p class="card-text">Accumulated value from all order checkouts.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card text-white bg-success mb-3">
            <div class="card-header">Total Books Sold</div>
            <div class="card-body">
                <h2 class="card-title">@Model.TotalBooksSold copies</h2>
                <p class="card-text">Total quantity of books checked out by customers.</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Top-Selling Books</h5>
            </div>
            <div class="card-body px-0 py-2">
                <ul class="list-group list-group-flush">
                    @if (Model.TopSellingBooks.Count == 0)
                    {
                        <li class="list-group-item text-center text-muted">No sales recorded yet.</li>
                    }
                    else
                    {
                        @foreach (var book in Model.TopSellingBooks)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@book.Title</strong><br/>
                                    <small class="text-muted">by @book.Author</small>
                                </div>
                                <span class="badge bg-primary rounded-pill">@book.SoldCount sold</span>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Sales by Category</h5>
            </div>
            <div class="card-body px-0 py-2">
                <ul class="list-group list-group-flush">
                    @if (Model.SalesByCategory.Count == 0)
                    {
                        <li class="list-group-item text-center text-muted">No sales recorded yet.</li>
                    }
                    else
                    {
                        @foreach (var cat in Model.SalesByCategory)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>@cat.CategoryName</span>
                                <strong class="text-success">@cat.TotalSales.ToString("C")</strong>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row mt-2">
    <div class="col-12 mb-4">
        <div class="card">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Most Active Customers</h5>
            </div>
            <div class="card-body px-0 py-2">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr class="table-light">
                            <th class="ps-4">Customer Name</th>
                            <th>Email Address</th>
                            <th class="pe-4 text-end">Order Count</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ActiveCustomers.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-3">No customers found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var cust in Model.ActiveCustomers)
                            {
                                <tr>
                                    <td class="ps-4"><strong>@cust.CustomerName</strong></td>
                                    <td><code>@cust.CustomerEmail</code></td>
                                    <td class="pe-4 text-end"><span class="badge bg-secondary">@cust.OrderCount orders</span></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
